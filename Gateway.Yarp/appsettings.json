{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "graphql-route": {
        "ClusterId": "graphql-cluster",
        "Match": {
          "Path": "/graphql/{**catch-all}",
          "Methods": [ "GET", "POST" ]
        },
        "Transforms": [
          { "PathRemovePrefix": "/graphql" },
          { "PathPrefix": "/graphql" }
        ]
      },
      "rest-masterdata-route": {
        "ClusterId": "masterdata-cluster",
        "Match": {
          "Path": "/api/masterdata/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/masterdata" }
        ]
      },
      "rest-productioncontrol-route": {
        "ClusterId": "productioncontrol-cluster",
        "Match": {
          "Path": "/api/productioncontrol/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/productioncontrol" }
        ]
      }
    },
    "Clusters": {
      "graphql-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5000"
          }
        }
      },
      "masterdata-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "productioncontrol-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5001"
          }
        }
      }
    }
  }
}
